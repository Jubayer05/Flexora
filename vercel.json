{
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "backend": {
      "entrypoint": "backend/main.ts",
      "routePrefix": "/_/backend",
      "framework": "express",
      "includeFiles": [
        "backend/node_modules/.prisma/**",
        "backend/node_modules/@prisma/**",
        "backend/node_modules/axios/**",
        "backend/node_modules/follow-redirects/**",
        "backend/node_modules/proxy-from-env/**",
        "backend/node_modules/form-data/**"
      ]
    }
  }
}
