# Database Configuration (backend is on host network → use localhost)
# DATABASE_URL="postgresql://uhq_user:uhq_password@localhost:5432/uhq_database?schema=public"
POSTGRES_USER=uhq_user
POSTGRES_PASSWORD=uhq_password
POSTGRES_DB=uhq_database
POSTGRES_HOST=postgres
POSTGRES_PORT=5433

# Redis Configuration (note: you mapped 6380->6379 earlier)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=uhq_redis_password
# REDIS_URL="redis://:uhq_redis_password@localhost:6380"
DATABASE_URL="YOUR_DATABASE_URL"
REDIS_URL="YOUR_REDIS_URL"


# Python service URL (backend sees host ports)
PYTHON_SERVICE_URL=http://localhost:8000

# Application Configuration
NODE_ENV=development
PORT=5000
APP_PORT=5000
FRONTEND_URL="http://localhost:3000"

# JWT Configuration (Regular User Authentication)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-jwt-refresh-key-change-this-in-production

# Admin JWT Configuration (Separate secrets for enhanced security)
ADMIN_JWT_SECRET=your-super-secret-admin-jwt-key-change-this-in-production
ADMIN_JWT_REFRESH_SECRET=your-super-secret-admin-jwt-refresh-key-change-this-in-production

# Encryption Configuration
ENCRYPTION_KEY="uhq_backend_default_key_32chars!"

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook/telegram

# Telegram API Configuration (for Python OTP Service)
TELEGRAM_API_ID="YOUR_TELEGRAM_API_ID"
TELEGRAM_API_HASH="YOUR_TELEGRAM_API_HASH"

# Payment Gateway Configuration (examples)
BINANCE_API_KEY=YOUR_BINANCE_API_KEY
BINANCE_SECRET_KEY=YOUR_BINANCE_SECRET_KEY

# Email Configuration
SMTP_HOST=YOUR_SMTP_HOST
SMTP_PORT=587
SMTP_USER=YOUR_SMTP_USER
SMTP_PASSWORD=YOUR_SMTP_PASSWORD
SMTP_FROM_EMAIL=YOUR_SMTP_FROM_EMAIL
SMTP_FROM_NAME="YOUR_SMTP_FROM_NAME"

# Image Service Configuration
IMAGEKIT_PUBLIC_KEY=YOUR_IMAGEKIT_PUBLIC_KEY
IMAGEKIT_PRIVATE_KEY=YOUR_IMAGEKIT_PRIVATE_KEY
IMAGEKIT_URL_ENDPOINT=YOUR_IMAGEKIT_URL_ENDPOINT

# Session Configuration (for Telegram)
SESSION_LENGTH=900

# App Info
APP_NAME="YOUR_APP_NAME"
APP_VERSION="1.0.0"
# # IMPORTANT: must be public in production (PayGate bot must reach it)
# # In dev you can use ngrok: https://xxxx.ngrok-free.app
# BACKEND_PUBLIC_URL=http://localhost:5000

# # Your existing webhook base should become:
# # public webhooks base (ngrok)
# PAYMENT_CALLBACK_URL=https://f9734cb52e75.ngrok-free.app/api/v1/webhooks

# # your secret to prevent fake callbacks
# PAYGATE_CALLBACK_SECRET=uhq_paygate_cb_secret_2026_very_long_random

# # PayGate endpoints - Uses /crypto/{ticker}/ path format with ticker like "polygon/usdc"
# PAYGATE_CONTROL_BASE_URL=https://api.paygate.to
# PAYGATE_WALLET_ENDPOINT=wallet.php
# PAYGATE_PROCESS_PAYMENT_ENDPOINT=payment.php
# PAYGATE_CONVERT_ENDPOINT=convert.php
# PAYGATE_METHOD=polygon/usdc


# Payment URLS
PAYMENT_SUCCESS_URL=http://localhost:3000/payment/success
PAYMENT_CANCEL_URL=YOUR_PAYMENT_CANCEL_URL
SUBSCRIPTION_SUCCESS_URL=http://localhost:3000/subscription/payment/success
SUBSCRIPTION_CANCEL_URL=YOUR_SUBSCRIPTION_CANCEL_URL

# FIRST ADMIN
ADMIN_EMAIL=YOUR_ADMIN_EMAIL
ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD

PAYMENT_CALLBACK_URL=http://localhost:5000/api/v1/webhooks

# IMPORTANT: must be public in production (PayGate bot must reach it)
# In dev you can use ngrok: https://xxxx.ngrok-free.app
# BACKEND_PUBLIC_URL=http://localhost:5000

# Your existing webhook base should become:
# public webhooks base (ngrok)
# PAYMENT_CALLBACK_URL=https://agueda-hitchy-botanically.ngrok-free.dev/api/v1/webhooks

# your secret to prevent fake callbacks
PAYGATE_CALLBACK_SECRET=YOUR_PAYGATE_CALLBACK_SECRET

# PayGate endpoints
# Base URL must be WITHOUT /control.
# Direct crypto wallet endpoint pattern: {baseURL}/crypto/{method}/{endpoint}
# Hosted checkout token endpoint: {baseURL}/control/wallet.php
PAYGATE_CONTROL_BASE_URL=YOUR_PAYGATE_CONTROL_BASE_URL
PAYGATE_WALLET_ENDPOINT=YOUR_PAYGATE_WALLET_ENDPOINT
# Optional override for hosted checkout wallet creation endpoint
# PAYGATE_HOSTED_WALLET_ENDPOINT=/control/wallet.php
PAYGATE_PROCESS_PAYMENT_ENDPOINT=YOUR_PAYGATE_PROCESS_PAYMENT_ENDPOINT
PAYGATE_CONVERT_ENDPOINT=YOUR_PAYGATE_CONVERT_ENDPOINT
PAYGATE_PAYOUT_COIN=YOUR_PAYGATE_PAYOUT_COIN

# IMPORTANT: PayGate uses CRYPTO TICKERS in format {blockchain}/{token}
# Use FORWARD SLASH, not underscore! Example: polygon/usdc NOT polygon_usdc
# Format examples: polygon/usdc, erc20/usdc, polygon/usdt, arbitrum/usdc, bep20/usdc
# This creates endpoint: /crypto/polygon/usdc/wallet.php
PAYGATE_METHOD=YOUR_PAYGATE_METHOD

# Optional hosted checkout domain override.
# Default is checkout.paygate.to (recommended for hosted PayGate pages).
# Set this only if PayGate requires a specific custom domain for your account.
# PAYGATE_CHECKOUT_DOMAIN=checkout.paygate.to

FRONTEND_URL=http://localhost:3000
