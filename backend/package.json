{
  "name": "uhq-backend",
  "main": "index.js",
  "module": "index.js",
  "type": "module",
  "private": true,
  "imports": {
    "@prisma/client": "./generated/prisma/index.js",
    "@prisma/client/*": "./generated/prisma/*"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "build": "prisma generate && node esbuild.config.mjs",
    "dev": "bun --watch main.ts",
    "start": "node index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:sync": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:resolve": "prisma migrate resolve",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:reset": "prisma migrate reset",
    "db:seed": "bun prisma/seed.ts",
    "db:studio": "prisma studio",
    "check": "tsc --noEmit --skipLibCheck",
    "bootstrap:binance": "bun scripts/bootstrapLogin.ts",
    "bootstrap:binance:firefox": "bun scripts/bootstrapLogin-firefox.ts",
    "save:cookies": "bun scripts/saveCookies.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/ioredis": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/nodemailer": "^7.0.2",
    "@types/pdfkit": "^0.17.3",
    "esbuild": "^0.25.12",
    "prettier": "^3.6.2",
    "prisma": "^7",
    "tsx": "^4.21.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.990.0",
    "@prisma/adapter-pg": "^7",
    "@prisma/client": "^7",
    "@types/bcrypt": "^6.0.0",
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "big-integer": "^1.6.52",
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "google-auth-library": "^10.5.0",
    "imagekit": "^6.0.0",
    "import": "^0.0.6",
    "input": "^1.0.1",
    "ioredis": "^5.7.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.6",
    "otplib": "^12.0.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.17.2",
    "playwright": "^1.47.2",
    "redis": "^4.7.0",
    "socket.io": "^4.8.3",
    "socks-proxy-agent": "^8.0.5",
    "stripe": "^19.1.0",
    "zod": "^4.1.5"
  }
}
